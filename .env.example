# API keys for data acquisition (all free registration).
# Copy this file to .env and fill in your keys.
#
# NOTE: API keys are OPTIONAL. The pipeline downloads all data from
# bulk public endpoints that do not require authentication. Keys are
# only needed if you want to use the Census/BLS/BEA APIs directly.

# BLS: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Census Bureau: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BEA: https://apps.bea.gov/api/signup/
BEA_API_KEY=
